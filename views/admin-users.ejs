<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Admin | Manage Users</title>
    <style>
        body { background-color: #0f1322; color: white; }
        .sidebar { background: #161b30; height: 100vh; width: 250px; position: fixed; padding: 20px; }
        .main { margin-left: 270px; padding: 40px; }
        .table { color: white !important; background: #1d233d; border-radius: 10px; overflow: hidden; }
        .nav-link { color: #8b9bb4; margin-bottom: 10px; }
        .nav-link.active { color: white; background: rgba(255,255,255,0.1); border-radius: 8px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h4 class="text-primary fw-bold mb-4">Freelance Admin</h4>
        <nav class="nav flex-column">
            <a class="nav-link" href="/admin-dashboard">Dashboard</a>
            <a class="nav-link active" href="/admin/users">Users</a>
            <a class="nav-link" href="/admin/projects">Projects</a>
            <a class="nav-link" href="/admin/disputes">Disputes</a>
            <a class="nav-link" href="/admin/tickets">Support Tickets</a>
            <a class="nav-link text-danger mt-5" href="/logout">Logout</a>
        </nav>
    </div>

    <div class="main">
        <h3 class="fw-bold mb-4">User Management</h3>
        <table class="table table-hover mt-3">
            <thead>
                <tr class="text-muted">
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Wallet</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.name %></td>
                        <td><%= u.email %></td>
                        <td><span class="badge bg-secondary"><%= u.role %></span></td>
                        <td>$<%= u.wallet || 0 %></td>
                        <td>
                            <form action="/admin/delete-user/<%= u._id %>" method="POST" onsubmit="return confirm('Delete this user?')">
                                <button class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>