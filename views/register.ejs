<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Register | Milestone-Pay</title>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-5">
                        <h3 class="text-center mb-4 fw-bold">Create Account</h3>
                        
                        <form action="/register" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="name" class="form-control" placeholder="Enter your full name" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="name@example.com" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" placeholder="Create a password" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">I want to...</label>
                                <select name="role" id="roleSelect" class="form-select" required onchange="toggleFreelancerFields()">
                                    <option value="" disabled selected>-- Choose your role --</option>
                                    <option value="freelancer">Work as a Freelancer</option>
                                    <option value="client">Hire a Freelancer</option>
                                </select>
                            </div>

                            <div id="freelancerFields" style="display: none;">
                                <div class="mb-3">
                                    <label class="form-label text-primary fw-bold">Professional Bio</label>
                                    <textarea name="bio" class="form-control" rows="3" placeholder="Describe your skills and expertise..."></textarea>
                                    <small class="text-muted">You can upload your resume file from the dashboard after signing up.</small>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mt-3">Create Account</button>
                        </form>

                        <hr class="my-4">
                        <p class="text-center mb-0 text-muted">
                            Already have an account? <a href="/login" class="text-decoration-none">Login here</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleFreelancerFields() {
            const role = document.getElementById('roleSelect').value;
            const freelancerFields = document.getElementById('freelancerFields');
            
            // Show bio only if 'freelancer' is selected
            // Hide for 'client' and 'admin'
            if (role === 'freelancer') {
                freelancerFields.style.display = 'block';
            } else {
                freelancerFields.style.display = 'none';
            }
        }

        // Auto-select role from query parameter
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const roleParam = urlParams.get('role');
            if (roleParam) {
                const select = document.getElementById('roleSelect');
                // Check if the roleParam matches a valid option
                if (Array.from(select.options).some(opt => opt.value === roleParam)) {
                    select.value = roleParam;
                    toggleFreelancerFields(); // Trigger the UI update
                }
            }
        });
    </script>
</body>
</html>