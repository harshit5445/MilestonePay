<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <title>Dashboard | MilestonePay</title>
    <style>
        :root {
            --bg-deep: #0a0e1b;
            --bg-card: #141a2e;
            --bg-input: #1b243d;
            --text-main: #f8f9fa;
            --text-mute: #8b9bb4;
            --accent-blue: #0d6efd;
            --accent-green: #2ecc71;
            --accent-purple: #8e44ad;
            --accent-review: #f1c40f;
        }

        body { background-color: var(--bg-deep); color: var(--text-main); font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .nav-custom { background: var(--bg-deep) !important; border-bottom: 1px solid #1f2946; }
        .nav-link-custom { color: var(--text-mute) !important; font-size: 0.9rem; transition: 0.2s; }
        .nav-link-custom:hover, .nav-link-custom.active { color: var(--accent-blue) !important; }
        .card-custom { background: var(--bg-card); border: 1px solid #1f2946; border-radius: 16px; transition: 0.3s; color: var(--text-main); }
        .card-custom:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
        .search-input-custom { background-color: var(--bg-input) !important; border: 1px solid #2c3a5e !important; color: var(--text-main) !important; border-radius: 12px; }
        .search-input-custom::placeholder { color: var(--text-mute); }
        .btn-pill { border-radius: 50px; font-size: 0.8rem; padding: 6px 18px; font-weight: bold; border: 1px solid transparent; }
        .btn-outline-blue { border: 1px solid var(--accent-blue); color: var(--accent-blue); background: transparent; }
        .btn-outline-blue:hover { background: var(--accent-blue); color: var(--text-main); }
        .stat-box { background: rgba(255, 255, 255, 0.03); border-radius: 10px; padding: 15px; flex: 1; text-align: center; }
        .stat-label { color: var(--text-mute); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }

        .m-completed { border-left: 5px solid var(--accent-green) !important; }
        .m-review { border-left: 5px solid var(--accent-review) !important; }
        .m-pending { border-left: 5px solid var(--accent-blue) !important; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg nav-custom mb-5 shadow-sm">
    <div class="container py-2">
        <a class="navbar-brand text-primary fw-bold fs-4" href="/dashboard">MilestonePay</a>
        <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <li class="nav-item"><a class="nav-link nav-link-custom active" href="/dashboard">Browse</a></li>
                <li class="nav-item"><a class="nav-link nav-link-custom" href="/completed-projects">Archive</a></li>
                <li class="nav-item"><a class="nav-link nav-link-custom" href="/earnings">Wallet</a></li>
                <li class="nav-item ms-3">
                    <span class="text-mute small me-2 d-none d-lg-inline">Logged in: <strong><%= profile.name %></strong></span>
                    <a href="/logout" class="btn btn-outline-danger btn-sm px-3" style="border-radius:50px;">Logout</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mb-5">
    <div class="row g-4">
        
        <div class="col-md-3">
            <div class="card-custom p-4 text-center mb-4 sticky-top" style="top: 20px;">
                <img src="https://ui-avatars.com/api/?name=<%= profile.name %>&background=random" class="rounded-circle mx-auto mb-3" width="80">
                <h5 class="mb-1 fw-bold text-white"><%= profile.name %></h5>
                <p class="text-mute small mb-3 text-capitalize"><%= profile.role %></p>
                
                <div class="d-flex gap-3 mt-3">
                    <div class="stat-box">
                        <div class="fw-bold text-white" style="font-size: 1rem;"><%= profile.rating ? '★ ' + profile.rating : 'No Rating' %></div>
                        <div class="stat-label mt-1">Rating</div>
                    </div>
                    <% if (user.role === 'freelancer') { %>
                        <div class="stat-box">
                            <div class="fs-5 fw-bold text-success">$<%= (totalEarnings / 1000).toFixed(1) %>k</div>
                            <div class="stat-label">Earned</div>
                        </div>
                    <% } else { %>
                        <div class="stat-box">
                            <div class="fs-5 fw-bold text-primary"><%= myProjects.length %></div>
                            <div class="stat-label">Active</div>
                        </div>
                    <% } %>
                </div>

                <div class="mt-4 text-start">
                    <h6 class="fw-bold mb-3 small uppercase text-mute">Profile Action</h6>
                    <a href="/edit-profile" class="btn btn-outline-blue w-100 btn-pill">Edit Settings</a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            
            <% if (user.role === 'freelancer') { %>
                <div class="mb-4">
                    <form action="/dashboard" method="GET">
                        <input type="text" name="search" class="form-control form-control-lg search-input-custom" 
                               placeholder="Search for projects or skills..." value="<%= searchQuery %>">
                    </form>
                </div>
            <% } %>

            <% if (user.role === 'client') { %>
                <div class="card-custom p-4 mb-5 shadow-sm">
                    <h5 class="fw-bold mb-3 text-white">🚀 Create New Milestone Project</h5>
                    <form action="/post-job" method="POST" class="row g-2">
                        <div class="col-md-8">
                            <input type="text" name="title" class="form-control search-input-custom" placeholder="Project title (e.g. Website Development)" required>
                        </div>
                        <div class="col-md-2">
                            <input type="number" name="budget" class="form-control search-input-custom" placeholder="Budget $" required>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100 fw-bold btn-pill">Post</button>
                        </div>
                    </form>
                </div>

                <h4 class="fw-bold mb-3 text-mute small uppercase">Browse Freelancers</h4>
                <div class="row mb-5">
                    <% if (allFreelancers.length === 0) { %>
                        <div class="col-12"><p class="text-mute">No freelancers found.</p></div>
                    <% } else { %>
                        <% allFreelancers.forEach(talent => { %>
                            <div class="col-md-4 mb-3">
                                <div class="card-custom p-3 text-center">
                                    <img src="https://ui-avatars.com/api/?name=<%= talent.name %>" class="rounded-circle mb-2" width="50">
                                    <h6 class="fw-bold text-white mb-0"><%= talent.name %></h6>
                                    <p class="small text-mute mb-2"><%= talent.skills || 'Specialist' %></p>
                                    <a href="/profile/<%= talent._id %>" class="btn btn-sm btn-outline-blue btn-pill w-100">View Profile</a>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            <% } %>

            <% if (user.role === 'freelancer') { %>
                <h4 class="fw-bold mb-3 text-mute small uppercase">Available Opportunities</h4>
                <div class="row mb-5">
                    <% if (openJobs.length === 0) { %>
                        <div class="col-12"><div class="alert alert-dark border border-secondary text-mute">No available jobs found.</div></div>
                    <% } else { %>
                        <% openJobs.forEach(job => { %>
                            <div class="col-12 mb-3">
                                <div class="card-custom p-4">
                                    <div class="row align-items-center">
                                        <div class="col-md-9">
                                            <p class="small uppercase text-primary fw-bold mb-1">Open Contract</p>
                                            <h5 class="fw-bold mb-1 text-white"><%= job.title %></h5>
                                            <p class="small text-white opacity-75 mb-0">Full milestone protection included.</p>
                                        </div>
                                        <div class="col-md-3 text-end border-start border-secondary border-opacity-25 pl-4">
                                            <% let total = job.milestones.reduce((acc, m) => acc + parseInt(m.amount), 0); %>
                                            <div class="fs-3 fw-bold text-white mb-3">$<%= total %></div>
                                            <a href="/request-job/<%= job._id %>" class="btn btn-sm btn-outline-blue fw-bold btn-pill w-100 py-2">Apply Now</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            <% } %>

            <h4 class="fw-bold mb-3 text-mute small uppercase pt-4">My Ongoing Work</h4>
            <% if (myProjects.length === 0) { %>
                <div class="alert alert-dark border border-secondary text-mute">No active projects to track.</div>
            <% } else { %>
                <% myProjects.forEach(project => { %>
                    <div class="card-custom mb-4 overflow-hidden shadow-sm">
                        <div class="card-header bg-transparent py-3 px-4 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid #1f2946;">
                            <span class="fw-bold fs-5 text-white"><%= project.title %></span>
                            <div>
                                <span class="badge rounded-pill bg-primary px-3 py-1 text-uppercase small me-2"><%= project.status %></span>
                                <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#ticketModal<%= project._id %>">Get Help</button>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <% if (user.role === 'client' && project.status === 'requested') { %>
                                <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex justify-content-between align-items-center">
                                    <span class="small fw-bold text-dark">📩 Hire Request: <%= project.applicantName %></span>
                                    <a href="/hire-freelancer/<%= project._id %>" class="btn btn-sm btn-success px-4 fw-bold shadow-sm">Confirm Hire</a>
                                </div>
                            <% } %>

                            <% project.milestones.forEach(m => { %>
                                <% 
                                    let statusClass = 'm-pending';
                                    if(m.status === 'Completed') statusClass = 'm-completed';
                                    if(m.status === 'Under Review') statusClass = 'm-review';
                                %>
                                <div class="p-3 rounded mb-3 border-start border-4 <%= statusClass %>" 
                                     style="background: rgba(255,255,255,0.02); border: 1px solid #1f2946;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="fw-bold small text-mute text-uppercase" style="font-size: 0.7rem;"><%= m.title %></span><br>
                                            <span class="fw-bold fs-5 text-white">$<%= m.amount %></span>
                                            
                                            <% if (user.role === 'client' && m.proof) { %>
                                                <div class="mt-2">
                                                    <a href="<%= m.proof %>" target="_blank" class="text-info small text-decoration-none">
                                                        🔗 View Submission Link
                                                    </a>
                                                </div>
                                            <% } %>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge rounded-pill <%= m.status === 'Completed' ? 'bg-success' : (m.status === 'Under Review' ? 'bg-warning text-dark' : 'bg-primary') %> mb-2">
                                                <%= m.status %>
                                            </span>
                                            
                                            <% if (user.role === 'freelancer' && m.status === 'Pending' && project.status === 'active') { %>
                                                <form action="/submit/<%= project._id %>/<%= m.id %>" method="POST" class="d-flex gap-2 mt-1">
                                                    <input type="text" name="proofLink" class="form-control form-control-sm search-input-custom" placeholder="Link to proof" required>
                                                    <button class="btn btn-sm btn-pill btn-outline-blue px-3">Submit</button>
                                                </form>
                                            <% } %>

                                            <% if (user.role === 'client' && m.status === 'Under Review') { %>
                                                <div class="d-flex gap-2 justify-content-end mt-1">
                                                    <form action="/dispute/<%= project._id %>/<%= m.id %>" method="POST">
                                                        <button class="btn btn-sm btn-pill btn-danger px-4 shadow-sm">Dispute</button>
                                                    </form>
                                                    <form action="/approve/<%= project._id %>/<%= m.id %>" method="POST">
                                                        <button class="btn btn-sm btn-pill btn-success px-4 shadow-sm">Approve & Release</button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Ticket Modal -->
                    <div class="modal fade" id="ticketModal<%= project._id %>" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content" style="background-color: var(--bg-card); border: 1px solid #1f2946;">
                                <div class="modal-header border-bottom-0">
                                    <h5 class="modal-title fw-bold text-white">Report Issue</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <form action="/raise-ticket/<%= project._id %>" method="POST">
                                    <div class="modal-body">
                                        <p class="text-mute small mb-4">Having trouble with this project? Let us know and our support team will review the issue.</p>
                                        <div class="mb-3">
                                            <label class="form-label text-white small">Reason for Ticket</label>
                                            <select name="reason" class="form-select search-input-custom" required>
                                                <option value="" disabled selected>Select a reason...</option>
                                                <option value="Unresponsive Counterparty">Unresponsive Client/Freelancer</option>
                                                <option value="Missed Deadline">Missed Deadline</option>
                                                <option value="Quality Issues">Quality Issues</option>
                                                <option value="Harassment/Abuse">Harassment or Abuse</option>
                                                <option value="Other">Other</option>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label text-white small">Description</label>
                                            <textarea name="description" class="form-control search-input-custom" rows="4" placeholder="Please provide details about your issue..." required></textarea>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-top-0">
                                        <button type="button" class="btn btn-outline-secondary btn-pill" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-warning btn-pill fw-bold">Submit Ticket</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</div>

</body>
</html>