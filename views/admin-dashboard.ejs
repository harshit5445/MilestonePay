<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Freelance Admin | Milestone-Pay</title>
    <style>
        :root {
            --bg-deep: #0f1322;
            --bg-side: #161b30;
            --bg-card: #1d233d;
            --text-main: #f8f9fa;
            --accent-purple: #8e44ad;
        }

        body { background-color: var(--bg-deep); color: var(--text-main); font-family: 'Segoe UI', sans-serif; }
        
        /* Sidebar Layout */
        .sidebar {
            background-color: var(--bg-side);
            height: 100vh;
            padding: 30px 20px;
            position: fixed;
            width: 250px;
            border-radius: 0 20px 20px 0;
            z-index: 1000;
        }

        .sidebar h4 { color: #a29bfe; font-weight: bold; margin-bottom: 40px; }

        .nav-link {
            color: #8b9bb4;
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

        .nav-link:hover, .nav-link.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }

        /* Main Content */
        .main-content { margin-left: 270px; padding: 40px; }

        .stat-card {
            background-color: var(--bg-card);
            border: none;
            border-radius: 15px;
            padding: 40px 20px;
            text-align: center;
            height: 100%;
        }

        .stat-label { color: #8b9bb4; font-size: 0.9rem; margin-bottom: 15px; }
        .stat-value { font-size: 3rem; font-weight: bold; }

    </style>
</head>
<body>

    <div class="sidebar shadow">
        <h4>Freelance Admin</h4>
        <nav class="nav flex-column">
            <a class="nav-link active" href="/admin-dashboard">Dashboard</a>
            <a class="nav-link" href="/admin/users">Users</a>
            <a class="nav-link" href="/admin/projects">Projects</a>
            <a class="nav-link" href="/admin/disputes">Disputes</a>
            <a class="nav-link" href="/admin/tickets">Support Tickets</a>
            <a class="nav-link mt-5 text-danger" href="/logout">Logout</a>
        </nav>
    </div>

    <div class="main-content">
        <h2 class="fw-bold mb-5">Dashboard Overview</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card stat-card shadow-sm">
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value text-white"><%= stats.users %></div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card shadow-sm">
                    <div class="stat-label">Total Projects</div>
                    <div class="stat-value text-white"><%= stats.projects %></div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card shadow-sm">
                    <div class="stat-label">Open Disputes</div>
                    <div class="stat-value text-warning"><%= stats.disputes %></div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>