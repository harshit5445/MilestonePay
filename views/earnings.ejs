<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Wallet | MilestonePay</title>
    <style>
        :root {
            --bg-deep: #0a0e1b;
            --bg-card: #141a2e; /* Matched to Dashboard Dark */
            --text-main: #f8f9fa;
            --text-mute: #8b9bb4;
            --accent-blue: #0d6efd;
        }

        body { 
            background-color: var(--bg-deep); 
            color: var(--text-main); 
            font-family: 'Inter', sans-serif; 
        }
        
        .balance-card {
            background-color: #f8f9fa; /* Light background for balance pop */
            border-radius: 20px;
            padding: 60px 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .balance-label {
            color: #6c757d;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 2px;
            font-size: 0.8rem;
        }

        .balance-amount {
            font-size: 5rem;
            font-weight: 800;
            color: #100f0f; 
            margin: 15px 0 30px 0;
        }

        .btn-withdraw {
            background-color: var(--bg-deep);
            color: #ffffff;
            font-weight: 700;
            border-radius: 50px;
            padding: 12px 40px;
            border: none;
            transition: 0.3s;
        }

        .btn-withdraw:hover {
            background-color: var(--accent-blue);
            transform: translateY(-2px);
        }

        .transaction-container {
            background-color: var(--bg-card);
            border-radius: 16px;
            border: 1px solid #1f2946;
            overflow: hidden;
        }

        .table { color: var(--text-main) !important; margin-bottom: 0; }
        .table thead { background: rgba(255, 255, 255, 0.05); }
        .table th { border: none; color: var(--text-mute); font-size: 0.75rem; text-transform: uppercase; padding: 15px 20px; }
        .table td { border-top: 1px solid #1f2946; padding: 15px 20px; vertical-align: middle; }

        .btn-back { color: var(--text-mute); text-decoration: none; font-size: 0.9rem; transition: 0.2s; }
        .btn-back:hover { color: white; }
    </style>
</head>
<body>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0 text-white">My Wallet</h3>
                <a href="/dashboard" class="btn-back">← Back to Dashboard</a>
            </div>

            <div class="balance-card mb-5 shadow-lg">
                <div class="balance-label">Available Balance</div>
                <div class="balance-amount">$<%= user.wallet || 0 %></div>
                <button class="btn-withdraw shadow">Withdraw to Bank</button>
            </div>

            <h6 class="fw-bold text-mute text-uppercase small mb-3">Transaction History</h6>
            <div class="transaction-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Project Details</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (history.length === 0) { %>
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <p class="text-mute m-0 opacity-50">No completed projects yet.</p>
                                </td>
                            </tr>
                        <% } else { %>
                            <% history.forEach(p => { %>
                                <tr>
                                    <td>
                                        <div class="fw-bold text-white"><%= p.title %></div>
                                        <small class="text-mute small">Contract ID: <%= p._id %></small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-success px-3 py-2" style="font-size: 0.6rem;">SUCCESS</span>
                                    </td>
                                    <td class="text-end fw-bold text-white">
                                        <% 
                                            // Calculate only the completed milestones for this display
                                            let earnings = p.milestones.reduce((acc, m) => acc + (m.status === 'Completed' ? parseInt(m.amount) : 0), 0);
                                        %>
                                        +$<%= earnings %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

</body>
</html>