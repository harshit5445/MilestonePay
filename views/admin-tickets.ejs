<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Admin | Support Tickets</title>
    <style>
        :root {
            --bg-deep: #0f1322;
            --bg-side: #161b30;
            --bg-card: #1d233d;
            --text-main: #f8f9fa;
        }

        body { background-color: var(--bg-deep); color: var(--text-main); font-family: 'Segoe UI', sans-serif; }
        
        .sidebar {
            background-color: var(--bg-side);
            height: 100vh;
            padding: 30px 20px;
            position: fixed;
            width: 250px;
            border-radius: 0 20px 20px 0;
        }

        .nav-link {
            color: #8b9bb4;
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            text-decoration: none;
            display: block;
        }

        .nav-link:hover, .nav-link.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .main-content { margin-left: 270px; padding: 40px; }

        .ticket-card {
            background-color: var(--bg-card);
            border-radius: 15px;
            border: 1px solid #2c3a5e;
            margin-bottom: 20px;
            padding: 20px;
        }

        .status-badge { font-size: 0.75rem; padding: 5px 12px; border-radius: 50px; font-weight: bold; }
        .bg-open { background-color: #f39c12; color: white; }
        .bg-resolved { background-color: #27ae60; color: white; }
    </style>
</head>
<body>

    <div class="sidebar shadow">
        <h4 class="text-primary fw-bold mb-4">Freelance Admin</h4>
        <nav class="nav flex-column">
            <a class="nav-link" href="/admin-dashboard">Dashboard</a>
            <a class="nav-link" href="/admin/users">Users</a>
            <a class="nav-link" href="/admin/projects">Projects</a>
            <a class="nav-link" href="/admin/disputes">Disputes</a>
            <a class="nav-link active" href="/admin/tickets">Support Tickets</a>
            <a class="nav-link mt-5 text-danger" href="/logout">Logout</a>
        </nav>
    </div>

    <div class="main-content">
        <h2 class="fw-bold mb-4">Support Tickets & Resolution Center</h2>
        
        <% if (tickets.length === 0) { %>
            <div class="alert alert-dark text-muted text-center py-5 border border-secondary" style="background: var(--bg-card);">
                No support tickets have been submitted.
            </div>
        <% } else { %>
            <div class="row">
                <% tickets.forEach(ticket => { %>
                    <div class="col-12">
                        <div class="ticket-card shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold text-white mb-1"><%= ticket.reason %></h5>
                                    <p class="text-muted small mb-0">Project ID: <span class="font-monospace"><%= ticket.projectId %></span></p>
                                </div>
                                <span class="status-badge <%= ticket.status === 'Open' ? 'bg-open' : 'bg-resolved' %>"><%= ticket.status %></span>
                            </div>
                            
                            <div class="p-3 mb-3" style="background: rgba(255,255,255,0.02); border-radius: 8px; border: 1px solid #2c3a5e;">
                                <p class="mb-0 text-light small"><%= ticket.description %></p>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="small text-muted">
                                    Reported by: <strong class="text-white"><%= ticket.reporterName %></strong> (<%= ticket.reporterRole %>) <br>
                                    <span style="font-size: 0.8em;"><%= new Date(ticket.createdAt).toLocaleString() %></span>
                                </div>
                                <% if (ticket.status === 'Open') { %>
                                    <form action="/admin/resolve-ticket/<%= ticket._id %>" method="POST">
                                        <button type="submit" class="btn btn-sm btn-success px-4 rounded-pill fw-bold shadow-sm">Mark as Resolved</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

</body>
</html>
