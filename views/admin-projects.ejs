<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Admin | Manage Projects</title>
    <style>
        :root {
            --bg-deep: #0f1322;
            --bg-side: #161b30;
            --bg-card: #1d233d;
            --text-main: #f8f9fa;
        }

        body { background-color: var(--bg-deep); color: var(--text-main); font-family: 'Segoe UI', sans-serif; }
        
        .sidebar {
            background-color: var(--bg-side);
            height: 100vh;
            padding: 30px 20px;
            position: fixed;
            width: 250px;
            border-radius: 0 20px 20px 0;
        }

        .nav-link {
            color: #8b9bb4;
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            text-decoration: none;
            display: block;
        }

        .nav-link:hover, .nav-link.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .main-content { margin-left: 270px; padding: 40px; }

        .project-table {
            background-color: var(--bg-card);
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid #2c3a5e;
        }

        .table { color: white !important; margin-bottom: 0; width: 100%; }
        .table thead { background: rgba(255,255,255,0.05); }
        .table th { border: none; color: #8b9bb4; font-size: 0.8rem; text-transform: uppercase; padding: 20px; }
        .table td { border-top: 1px solid #2c3a5e; padding: 20px; vertical-align: middle; }
        
        .status-badge { font-size: 0.7rem; padding: 5px 12px; border-radius: 50px; font-weight: bold; }
        .bg-requested { background-color: #0d6efd; color: white; }
        .bg-active { background-color: #007bff; color: white; }
    </style>
</head>
<body>

    <div class="sidebar shadow">
        <h4 class="text-primary fw-bold mb-4">Freelance Admin</h4>
        <nav class="nav flex-column">
            <a class="nav-link" href="/admin-dashboard">Dashboard</a>
            <a class="nav-link" href="/admin/users">Users</a>
            <a class="nav-link active" href="/admin/projects">Projects</a>
            <a class="nav-link" href="/admin/disputes">Disputes</a>
            <a class="nav-link" href="/admin/tickets">Support Tickets</a>
            <a class="nav-link mt-5 text-danger" href="/logout">Logout</a>
        </nav>
    </div>

    <div class="main-content">
        <h2 class="fw-bold mb-4">Project Management</h2>
        
        <div class="project-table shadow-sm">
            <table class="table">
                <thead>
                    <tr>
                        <th>Project Name</th>
                        <th>Client ID</th>
                        <th>Status</th>
                        <th class="text-end">Total Budget</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (projects.length === 0) { %>
                        <tr><td colspan="4" class="text-center py-5 text-muted">No projects found in the system.</td></tr>
                    <% } else { %>
                        <% projects.forEach(p => { %>
                            <tr>
                                <td><div class="fw-bold"><%= p.title %></div></td>
                                <td class="small text-muted font-monospace"><%= p.clientId %></td>
                                <td>
                                    <% 
                                        let currentStatus = (p.status || 'open').toLowerCase();
                                        let badgeClass = 'bg-primary'; 
                                        if(currentStatus === 'completed') badgeClass = 'bg-success';
                                        if(currentStatus === 'requested') badgeClass = 'bg-requested';
                                        if(currentStatus === 'active') badgeClass = 'bg-active';
                                    %>
                                    <span class="status-badge <%= badgeClass %>">
                                        <%= currentStatus.toUpperCase() %>
                                    </span>
                                </td>
                                <td class="text-end fw-bold text-info">
                                    $<%= p.milestones.reduce((acc, m) => acc + parseInt(m.amount), 0) %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>