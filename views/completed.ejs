<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Project Archive | MilestonePay</title>
    <style>
        :root {
            --bg-deep: #0a0e1b;
            --bg-card: #141a2e;
            --text-main: #f8f9fa;
            --text-mute: #8b9bb4;
            --accent-green: #2ecc71;
        }
        body { background-color: var(--bg-deep); color: var(--text-main); font-family: 'Inter', sans-serif; }
        .card-custom { background: var(--bg-card); border: 1px solid #1f2946; border-radius: 16px; }
        .nav-custom { background: var(--bg-deep) !important; border-bottom: 1px solid #1f2946; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg nav-custom mb-5">
    <div class="container py-2">
        <a class="navbar-brand text-primary fw-bold fs-4" href="/dashboard">MilestonePay</a>
        <div class="ms-auto">
            <a href="/dashboard" class="btn btn-outline-primary btn-sm px-4">Back to Dashboard</a>
        </div>
    </div>
</nav>

<div class="container">
    <h2 class="fw-bold mb-4">✅ Project Archive</h2>
    <p class="text-mute mb-5">History of all successfully completed and paid projects.</p>

    <div class="row">
        <% if (projects.length === 0) { %>
            <div class="col-12 text-center py-5">
                <div class="card-custom p-5">
                    <p class="text-mute m-0">No completed projects found in your history.</p>
                </div>
            </div>
        <% } else { %>
            <% projects.forEach(p => { %>
                <div class="col-md-6 mb-4">
                    <div class="card-custom p-4 shadow-sm" style="border-left: 5px solid var(--accent-green);">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="fw-bold mb-1"><%= p.title %></h5>
                                <span class="badge bg-success text-uppercase small">Completed</span>
                            </div>
                            <div class="text-end">
                                <small class="text-mute d-block">Total Paid</small>
                                <strong class="fs-5 text-success">
                                    $<%= p.milestones.reduce((acc, m) => acc + parseInt(m.amount), 0) %>
                                </strong>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

</body>
</html>